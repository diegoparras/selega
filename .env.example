# Copiá este archivo a .env y poné valores REALES. NUNCA subas .env a git.
#   cp .env.example .env   &&   editá .env

# --- PostgreSQL ---
POSTGRES_USER=selega
POSTGRES_PASSWORD=cambiame-por-una-contraseña-larga-y-fuerte
POSTGRES_DB=selega

# --- Admin que comisiona el sistema (superadmin) ---
SELEGA_ADMIN_EMAIL=admin@tu-consejo.org.ar
# Dejá esto VACÍO: en el primer arranque el server genera una contraseña fuerte y la
# imprime UNA vez en los logs (docker compose logs selega). Cambiala desde Admin después.
SELEGA_ADMIN_PASS=

# --- Seguridad / despliegue ---
# Poné 1 cuando Selega corra detrás de TLS (reverse proxy / HTTPS) → la cookie de sesión
# solo viaja por HTTPS. En HTTP plano dejalo en 0.
SELEGA_SECURE_COOKIE=0
# Puerto del host (la app escucha en 8080 dentro del contenedor):
SELEGA_PORT=8088

# --- IA en la nube (opcional) ---
# API key de OpenRouter. Mejor cargarla desde Admin (queda write-only en la base) que acá.
OPENROUTER_KEY=
